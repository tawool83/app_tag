# Uncomment this line to define a global platform for your project
platform :ios, '15.5'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
  end

  # image_cropper: fullScreen presentation 강제 적용 (하단 툴바 safe area 문제)
  # iOS 13+에서 기본 modalPresentationStyle이 .pageSheet(카드형)이라
  # TOCropViewController의 하단 편집 버튼이 홈 인디케이터 아래로 내려가는 문제 수정
  cropper_plugin_file = File.expand_path(
    '../.symlinks/plugins/image_cropper/ios/Classes/FLTImageCropperPlugin.m',
    __FILE__
  )
  if File.exist?(cropper_plugin_file)
    content = File.read(cropper_plugin_file)
    patched = content.gsub(
      '[topController presentViewController:cropViewController animated:YES completion:nil];',
      "cropViewController.modalPresentationStyle = UIModalPresentationFullScreen;\n            [topController presentViewController:cropViewController animated:YES completion:nil];"
    )
    File.write(cropper_plugin_file, patched) if content != patched
  end

  # flutter_contacts: iOS 13+ 씬 기반 앱에서 window가 nil이 되는 크래시 패치
  # UIApplication.shared.delegate!.window!!.rootViewController! → 안전한 옵셔널 체인
  plugin_file = File.expand_path(
    '../.symlinks/plugins/flutter_contacts/ios/Classes/SwiftFlutterContactsPlugin.swift',
    __FILE__
  )
  if File.exist?(plugin_file)
    content = File.read(plugin_file)
    patched = content.gsub(
      'let rootViewController = UIApplication.shared.delegate!.window!!.rootViewController!',
      'let rootViewController = (UIApplication.shared.connectedScenes' \
        '.compactMap { $0 as? UIWindowScene }' \
        '.flatMap { $0.windows }' \
        '.first(where: { $0.isKeyWindow })?.rootViewController)' \
        ' ?? UIApplication.shared.delegate?.window??.rootViewController' \
        ' ?? UIViewController()'
    )
    File.write(plugin_file, patched) if content != patched
  end
end
